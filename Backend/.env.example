# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/hiregenie
CLIENT_URL=http://localhost:5173
LOG_LEVEL=debug

# ─── Auth (Phase 1) ─────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── AI ─────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# ─── Jobs & realtime (Phase 2) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloud storage (Phase 3) ────────────────────────────
# Provider is auto-detected: S3 is used when AWS_ACCESS_KEY_ID is set,
# otherwise Cloudinary. Configure ONE of the two blocks below.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=ap-south-1
# S3_BUCKET=hiregenie-uploads

# How much extracted resume text to keep on the report doc for AI context
RESUME_TEXT_MAX_CHARS=8000

# ─── Email (Phase 3) ────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=HireGenie <noreply@yourdomain.com>
# Reports created within this many days get daily prep emails
PREP_REMINDER_DAYS=7
# Cron expression for the daily prep email (server time)
PREP_REMINDER_CRON=0 8 * * *

# ─── Payments (Phase 3) ─────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
MONTHLY_PLAN_AMOUNT_PAISE=49900
FREE_TIER_MONTHLY_LIMIT=3
